{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "bigbirdiesings",
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  
  "menu": {
    "items": [
      {
        "label": "Mop comments",
        "description": "Remove this comment and all child comments. This might take a few seconds to run.",
        "location": "comment",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/mop-comment"
      },
      

      {
        "label": "Mop post comments",
        "description": "Remove all comments of this post. This might take a few seconds to run.",
        "location": "post",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/mop-post"
      }
    ]
  },
  "forms": {
    "mopComment": "/internal/form/mop-comment-submit",
    "mopPost": "/internal/form/mop-post-submit"
  },
  
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install",
    "onPostCreate": "/internal/triggers/on-post-create",
    "onPostUpdate": "/internal/triggers/on-post-update",
    "onCommentCreate": "/internal/triggers/on-comment-create",
    "onCommentUpdate": "/internal/triggers/on-comment-update"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "permissions": {
    "reddit": true,
    "http": {
     "enable": true,
     "domains": ["reddit.kyro.ninja"]}
  },
  "dev": {
    "subreddit": "bigbirdiesings_dev"
  }
}